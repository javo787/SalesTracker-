MONGODB_URI=mongodb+srv://...
JWT_SECRET=your_secret_here
GOOGLE_CLIENT_ID=your_google_client_id
TELEGRAM_BOT_TOKEN=your_bot_token
ADMIN_TELEGRAM_ID=your_personal_chat_id
BACKEND_URL=https://your-backend-url.onrender.com
PORT=3000
ALLOWED_ORIGINS=https://savdo.app
ADS_API_URL=https://your-ads-service.vercel.app

# --- Голосовой пайплайн продаж (backend/routes/voiceSale.ts) ---
# Gemini: до 4 ключей ротируются по кругу (rate-limit/403 на одном -> следующий).
# Бесплатные лимиты считаются ПО ПРОЕКТУ в Google Cloud, а не по ключу,
# поэтому реальный выигрыш даёт только создание ключей в РАЗНЫХ проектах/аккаунтах.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Groq: Whisper (STT) + Llama 3.3 70B (текстовый fallback), бесплатно, без карты.
GROQ_API_KEY=your_groq_api_key

# Cerebras: опционально, ещё один бесплатный (без карты) провайдер для
# текстовой JSON-экстракции — независимая от Google/Groq инфраструктура,
# добавляет резервный уровень в пайплайн. Получить ключ: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
