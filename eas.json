{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ADS_API_URL": "https://savdo-tan.vercel.app",
        "EXPO_PUBLIC_API_URL": "https://savdoapp.onrender.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ADS_API_URL": "https://savdo-tan.vercel.app",
        "EXPO_PUBLIC_API_URL": "https://savdoapp.onrender.com"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_ADS_API_URL": "https://savdo-tan.vercel.app",
        "EXPO_PUBLIC_API_URL": "https://savdoapp.onrender.com"
      }
    }
  }
}