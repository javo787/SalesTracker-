{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ADS_API_URL": "https://torgo.vercel.app",
        "EXPO_PUBLIC_API_URL": "https://savdoapp.onrender.com",
        "EXPO_PUBLIC_TELEGRAM_BOT_USERNAME": "Torgo_support_bot"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ADS_API_URL": "https://torgo.vercel.app",
        "EXPO_PUBLIC_API_URL": "https://savdoapp.onrender.com",
        "ORG_GRADLE_PROJECT_reactNativeArchitectures": "arm64-v8a",
        "EXPO_PUBLIC_TELEGRAM_BOT_USERNAME": "Torgo_support_bot"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_ADS_API_URL": "https://torgo.vercel.app",
        "EXPO_PUBLIC_API_URL": "https://savdoapp.onrender.com",
        "EXPO_PUBLIC_TELEGRAM_BOT_USERNAME": "Torgo_support_bot"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "alpha",
        "releaseStatus": "completed"
      }
    }
  }
}